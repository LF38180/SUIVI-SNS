generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  ELU
}

enum Categorie {
  AXE_1
  AXE_2
  AXE_3
  AXE_4
  HORS_PROGRAMME
}

enum TypePiece {
  PHOTO
  DOCUMENT
  LIEN
}

enum StatutProposition {
  EN_ATTENTE
  VALIDEE
  REFUSEE
}

model User {
  id             Int     @id @default(autoincrement())
  nom            String
  email          String  @unique
  motDePasseHash String
  role           Role    @default(ELU)
  actif          Boolean @default(true)
  fonction       String?
  deletedAt      DateTime? // corbeille (soft-delete) — restaurable
  anonymiseLe    DateTime? // RGPD : compte d'un élu sortant anonymisé

  mesuresReferent Mesure[]           @relation("Referent")
  mesuresAdjoint  Mesure[]           @relation("Adjoint")
  coReferences    MesureCoReferent[]
  propositions    Proposition[]      @relation("Auteur")
  validations     Proposition[]      @relation("Validateur")
  journalEntrees  JournalEntree[]
  piecesJointes   PieceJointe[]
  notifications   Notification[]
}

model Mesure {
  id               Int       @id @default(autoincrement())
  categorie        Categorie
  rubrique         String
  intitule         String
  natureCout       String?
  ordreGrandeur    String?
  besoins          String?
  limites          String?
  echeanceCible    DateTime?
  avancementPublie Int       @default(0)
  ordre            Int       @default(0)
  deletedAt        DateTime? // corbeille (soft-delete) — restaurable 30j

  // visibilité champ par champ pour la vue publique (§8.4)
  coutPublic    Boolean @default(false)
  limitesPublic Boolean @default(false)

  eluReferentId         Int?
  eluReferent           User? @relation("Referent", fields: [eluReferentId], references: [id])
  adjointRattachementId Int?
  adjointRattachement   User? @relation("Adjoint", fields: [adjointRattachementId], references: [id])

  propositions   Proposition[]
  journalEntrees JournalEntree[]
  piecesJointes  PieceJointe[]
  historique     Historique[]
  coReferents    MesureCoReferent[]
}

// Journal d'audit : trace les actions admin sensibles (qui, quoi, quand).
model AuditLog {
  id        Int      @id @default(autoincrement())
  auteurId  Int?
  auteurNom String   // dénormalisé : reste lisible même si le compte est anonymisé
  action    String   // ex "mesure.edition", "compte.desactivation", "mesure.suppression"
  cible     String?  // ex "Mesure #12", "Compte Jean Dupont"
  details   String?
  date      DateTime @default(now())

  @@index([date])
}

// Notifications in-app (cloche). Destinataire = un user. Générées par le système
// (proposition créée → admins ; proposition validée/refusée → auteur ; etc.).
model Notification {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  message     String
  lien        String?
  lue         Boolean  @default(false)
  creeeLe     DateTime @default(now())

  @@index([userId, lue])
}

// Co-référents d'une mesure (sujets transversaux) : N élus associés en plus
// du référent principal (eluReferentId) et de l'adjoint de rattachement.
model MesureCoReferent {
  mesureId Int
  mesure   Mesure @relation(fields: [mesureId], references: [id], onDelete: Cascade)
  userId   Int
  user     User   @relation(fields: [userId], references: [id])

  @@id([mesureId, userId])
}

model Proposition {
  id                Int               @id @default(autoincrement())
  mesureId          Int
  mesure            Mesure            @relation(fields: [mesureId], references: [id])
  auteurId          Int
  auteur            User              @relation("Auteur", fields: [auteurId], references: [id])
  avancementPropose Int
  commentaire       String?
  echeanceProposee  DateTime?
  statut            StatutProposition @default(EN_ATTENTE)
  motifRefus        String?
  valideeParId      Int?
  valideePar        User?             @relation("Validateur", fields: [valideeParId], references: [id])
  creeeLe           DateTime          @default(now())
  traiteeLe         DateTime?
}

model JournalEntree {
  id                Int      @id @default(autoincrement())
  mesureId          Int
  mesure            Mesure   @relation(fields: [mesureId], references: [id])
  auteurId          Int
  auteur            User     @relation(fields: [auteurId], references: [id])
  date              DateTime @default(now())
  commentaire       String
  avancementAssocie Int?
}

model PieceJointe {
  id           Int       @id @default(autoincrement())
  mesureId     Int
  mesure       Mesure    @relation(fields: [mesureId], references: [id])
  type         TypePiece
  url          String?   // pour les LIENS (ou null si fichier stocké en base)
  contenu      String?   // data URL base64 du fichier (PHOTO/DOCUMENT), stocké en base
  nomFichier   String?
  mimeType     String?
  legende      String?
  ajouteeParId Int
  ajouteePar   User      @relation(fields: [ajouteeParId], references: [id])
  date         DateTime  @default(now())
}

// Append-only : aucun UPDATE/DELETE dans le code (inaltérabilité §8.5)
model Historique {
  id              Int      @id @default(autoincrement())
  mesureId        Int
  mesure          Mesure   @relation(fields: [mesureId], references: [id])
  ancienPourcent  Int
  nouveauPourcent Int
  proposeParId    Int?
  valideeParId    Int?
  date            DateTime @default(now())
}
