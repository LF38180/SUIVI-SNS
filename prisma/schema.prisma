generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  ELU
}

enum Categorie {
  AXE_1
  AXE_2
  AXE_3
  AXE_4
  HORS_PROGRAMME
}

enum TypePiece {
  PHOTO
  DOCUMENT
  LIEN
}

enum StatutProposition {
  EN_ATTENTE
  VALIDEE
  REFUSEE
}

// Cycle de vie d'une mesure (surtout pour les initiatives hors programme proposées
// par les élus, qui attendent une validation admin avant d'exister).
enum StatutMesure {
  EN_ATTENTE
  VALIDEE
  REFUSEE
}

// Situation d'une mesure non encore réalisée (transparence du bilan, §crédibilité).
enum Situation {
  NORMALE // suit son cours
  REPORTEE // décalée, échéance révisée
  ADAPTEE // mise en œuvre différemment
  ABANDONNEE // ne sera pas faite, avec motif
}

model User {
  id             Int     @id @default(autoincrement())
  nom            String
  email          String  @unique
  motDePasseHash String
  role           Role    @default(ELU)
  actif          Boolean @default(true)
  fonction       String?
  doitChangerMdp Boolean @default(true) // bandeau "changer votre mot de passe" tant que vrai
  deletedAt      DateTime? // corbeille (soft-delete) — restaurable
  anonymiseLe    DateTime? // RGPD : compte d'un élu sortant anonymisé

  mesuresReferent Mesure[]           @relation("Referent")
  mesuresAdjoint  Mesure[]           @relation("Adjoint")
  coReferences    MesureCoReferent[]
  rattachements   MesureResponsable[] @relation("Rattachement")
  mesuresProposees Mesure[]          @relation("Proposant")
  propositions    Proposition[]      @relation("Auteur")
  validations     Proposition[]      @relation("Validateur")
  journalEntrees  JournalEntree[]
  piecesJointes   PieceJointe[]
  notifications   Notification[]
}

model Mesure {
  id               Int       @id @default(autoincrement())
  categorie        Categorie
  rubrique         String
  intitule         String
  natureCout       String?
  ordreGrandeur    String?
  besoins          String?
  limites          String?
  echeanceCible    DateTime?
  avancementPublie Int       @default(0)
  ordre            Int       @default(0)
  deletedAt        DateTime? // corbeille (soft-delete) — restaurable 30j
  situation        Situation @default(NORMALE) // reporté / adapté / abandonné (transparence)
  situationMotif   String?

  // visibilité champ par champ pour la vue publique (§8.4)
  coutPublic    Boolean @default(false)
  limitesPublic Boolean @default(false)

  // Ancien modèle (référent unique / adjoint / co-référents). CONSERVÉ pour ne rien
  // perdre, mais le code lit désormais `responsables` (modèle à plat ci-dessous).
  eluReferentId         Int?
  eluReferent           User? @relation("Referent", fields: [eluReferentId], references: [id])
  adjointRattachementId Int?
  adjointRattachement   User? @relation("Adjoint", fields: [adjointRattachementId], references: [id])

  // Qui a proposé cette mesure hors programme (null pour les 67 engagements du programme).
  proposeeParId Int?
  proposeePar   User? @relation("Proposant", fields: [proposeeParId], references: [id])
  // Cycle de vie d'une mesure. Les 67 engagements du programme sont VALIDEE.
  // Une initiative hors programme proposée par un élu naît EN_ATTENTE (validation
  // admin) puis devient VALIDEE (existe) ou REFUSEE (n'apparaît pas publiquement).
  statutMesure  StatutMesure @default(VALIDEE)
  motifRefus    String?

  propositions   Proposition[]
  journalEntrees JournalEntree[]
  piecesJointes  PieceJointe[]
  historique     Historique[]
  coReferents    MesureCoReferent[]
  responsables   MesureResponsable[]

  @@index([deletedAt])
  @@index([categorie])
  @@index([statutMesure])
}

// Modèle à plat : élus rattachés à une mesure. `role` distingue les RESPONSABLES
// (portent la mesure) des élus CONCERNES (associés). Tous apparaissent sur la fiche
// et voient la mesure dans « Mes mesures ». Remplace référent/adjoint/co-référents.
model MesureResponsable {
  mesureId Int
  mesure   Mesure         @relation(fields: [mesureId], references: [id], onDelete: Cascade)
  userId   Int
  user     User           @relation("Rattachement", fields: [userId], references: [id])
  role     RoleSurMesure  @default(RESPONSABLE)

  @@id([mesureId, userId])
  @@index([userId])
}

enum RoleSurMesure {
  RESPONSABLE
  CONCERNE
}

// Paramètres globaux de l'application (réglages admin clé/valeur).
model Parametre {
  cle    String @id
  valeur String
}

// Journal d'audit : trace les actions admin sensibles (qui, quoi, quand).
model AuditLog {
  id        Int      @id @default(autoincrement())
  auteurId  Int?
  auteurNom String   // dénormalisé : reste lisible même si le compte est anonymisé
  action    String   // ex "mesure.edition", "compte.desactivation", "mesure.suppression"
  cible     String?  // ex "Mesure #12", "Compte Jean Dupont"
  details   String?
  date      DateTime @default(now())

  @@index([date])
}

// Notifications in-app (cloche). Destinataire = un user. Générées par le système
// (proposition créée → admins ; proposition validée/refusée → auteur ; etc.).
model Notification {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  message     String
  lien        String?
  lue         Boolean  @default(false)
  creeeLe     DateTime @default(now())

  @@index([userId, lue])
}

// Co-référents d'une mesure (sujets transversaux) : N élus associés en plus
// du référent principal (eluReferentId) et de l'adjoint de rattachement.
model MesureCoReferent {
  mesureId Int
  mesure   Mesure @relation(fields: [mesureId], references: [id], onDelete: Cascade)
  userId   Int
  user     User   @relation(fields: [userId], references: [id])

  @@id([mesureId, userId])
}

model Proposition {
  id                Int               @id @default(autoincrement())
  mesureId          Int
  mesure            Mesure            @relation(fields: [mesureId], references: [id])
  auteurId          Int
  auteur            User              @relation("Auteur", fields: [auteurId], references: [id])
  avancementPropose Int
  commentaire       String?
  echeanceProposee  DateTime?
  statut            StatutProposition @default(EN_ATTENTE)
  motifRefus        String?
  valideeParId      Int?
  valideePar        User?             @relation("Validateur", fields: [valideeParId], references: [id])
  creeeLe           DateTime          @default(now())
  traiteeLe         DateTime?

  @@index([statut])
  @@index([mesureId])
}

model JournalEntree {
  id                Int      @id @default(autoincrement())
  mesureId          Int
  mesure            Mesure   @relation(fields: [mesureId], references: [id])
  auteurId          Int
  auteur            User     @relation(fields: [auteurId], references: [id])
  date              DateTime @default(now())
  commentaire       String
  avancementAssocie Int?

  // Chargé par mesureId + trié par date à chaque ouverture de fiche (sans cet index,
  // seq scan sur une table qui grossit à chaque mise à jour proposée).
  @@index([mesureId, date])
}

model PieceJointe {
  id           Int       @id @default(autoincrement())
  mesureId     Int
  mesure       Mesure    @relation(fields: [mesureId], references: [id])
  type         TypePiece
  url          String?   // pour les LIENS (ou null si fichier stocké en base)
  nomFichier   String?
  mimeType     String?
  legende      String?
  ajouteeParId Int
  ajouteePar   User      @relation(fields: [ajouteeParId], references: [id])
  date         DateTime  @default(now())
  // Une pièce jointe passe par validation admin avant d'être visible (comme un avancement)
  statut       StatutProposition @default(EN_ATTENTE)
  // Corbeille : suppression réversible (comme Mesure/User). Aucune donnée n'est perdue.
  deletedAt    DateTime?

  // Le contenu binaire lourd (base64) vit dans une table séparée : les requêtes
  // courantes (liste, fiche) ne le chargent JAMAIS. Sauvegardes plus souples.
  blob PieceJointeBlob?

  @@index([mesureId])
  @@index([statut])
  @@index([deletedAt])
}

// Contenu binaire d'une pièce jointe (data URL base64), isolé pour ne pas alourdir
// les requêtes sur PieceJointe. Relation 1-1.
model PieceJointeBlob {
  pieceJointeId Int         @id
  pieceJointe   PieceJointe @relation(fields: [pieceJointeId], references: [id], onDelete: Cascade)
  contenu       String // data URL base64
}

// Append-only : aucun UPDATE/DELETE dans le code (inaltérabilité §8.5)
model Historique {
  id              Int      @id @default(autoincrement())
  mesureId        Int
  mesure          Mesure   @relation(fields: [mesureId], references: [id])
  ancienPourcent  Int
  nouveauPourcent Int
  proposeParId    Int?
  valideeParId    Int?
  date            DateTime @default(now())

  @@index([date])
  @@index([mesureId, date])
}
