# Connexion Postgres Railway.
# En LOCAL : utiliser DATABASE_PUBLIC_URL de Railway (onglet Postgres > Variables).
# En PROD sur Railway : utiliser la référence interne ${{ Postgres.DATABASE_URL }}.
DATABASE_URL="postgresql://user:pass@host:port/db"

# Secret pour signer les cookies de session. Générer : openssl rand -hex 32
SESSION_SECRET="change-me"

# Mot de passe temporaire commun attribué à tous les comptes lors de l'import initial.
SEED_PASSWORD="change-me-temp"
